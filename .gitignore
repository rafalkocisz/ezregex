# ── CMake build directories ───────────────────────────────────────────────────
build*/
out*/

# ── CMake generated files (in-source, discouraged but just in case) ──────────
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
install_manifest.txt

# ── FetchContent cache (nanobench downloaded at configure time) ───────────────
_deps/

# ── Compiled output ───────────────────────────────────────────────────────────
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.pdb
*.ilk
*.exp

# ── MSVC / Visual Studio ──────────────────────────────────────────────────────
.vs/
*.vcxproj.user
*.suo
*.sdf
*.opensdf
*.VC.db
*.VC.opendb
x64/
x86/

# ── libFuzzer artifacts (crash inputs, slow units, leak reports) ──────────────
crash-*
slow-unit-*
leak-*
timeout-*
oom-*

# ── Editor / OS noise ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
